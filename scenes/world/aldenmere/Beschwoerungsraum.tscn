; === Cutscene Controller ===
[node name="IntroCutscene" type="Node" parent="."]
script = ExtResource("19_cutscene")

[connection signal="body_entered" from="Triggers/FocusTrigger" to="." method="OnFocusTriggerBodyEntered"]
[connection signal="body_exited" from="Triggers/FocusTrigger" to="." method="OnFocusTriggerBodyExited"]
[connection signal="body_entered" from="Triggers/AusgangTrigger" to="." method="OnAusgangTriggerBodyEntered"]
