[gd_scene load_steps=16 format=3 uid="uid://datasoul_beschwoerungsraum"]

[ext_resource type="Script" path="res://scripts/world/aldenmere/BeschwoerungsraumZone.cs" id="1_script"]
[ext_resource type="Script" path="res://scripts/cutscene/IntroCutscene.cs" id="19_cutscene"]
[ext_resource type="AudioStream" path="res://assets/audio/music/ambient_aldenmere.wav" id="3_ambient"]
[ext_resource type="PackedScene" path="res://assets/models/world/kenney_dungeon/room-small.glb" id="10_room_small"]
[ext_resource type="PackedScene" path="res://assets/models/world/kenney_dungeon/gate-door.glb" id="11_gate_door"]
[ext_resource type="PackedScene" path="res://assets/models/world/kenney_dungeon/stairs.glb" id="12_stairs"]
[ext_resource type="PackedScene" path="res://assets/models/world/kenney_dungeon/template-corner.glb" id="13_corner"]

[sub_resource type="BoxShape3D" id="BoxShape_floor"]
size = Vector3(14, 0.4, 14)

[sub_resource type="BoxShape3D" id="BoxShape_wallNS"]
size = Vector3(14, 8, 1)

[sub_resource type="BoxShape3D" id="BoxShape_wallEW"]
size = Vector3(1, 8, 14)

[sub_resource type="BoxShape3D" id="BoxShape_focusTrigger"]
size = Vector3(3, 3, 3)

[sub_resource type="BoxShape3D" id="BoxShape_ausgangTrigger"]
size = Vector3(3, 3, 2)

; === Partikel-Material (blau/golden, Rune-Licht-Partikel) ===
[sub_resource type="ParticleProcessMaterial" id="ParticleMat_Blue"]
direction = Vector3(0, 1, 0)
spread = 45.0
initial_velocity_min = 0.3
initial_velocity_max = 0.8
gravity = Vector3(0, 0.05, 0)
scale_min = 0.05
scale_max = 0.15
color = Color(0.3, 0.6, 1.0, 0.85)
emission_shape = 1
emission_sphere_radius = 0.3

[sub_resource type="ParticleProcessMaterial" id="ParticleMat_Gold"]
direction = Vector3(0, 1, 0)
spread = 30.0
initial_velocity_min = 0.2
initial_velocity_max = 0.6
gravity = Vector3(0, 0.02, 0)
scale_min = 0.04
scale_max = 0.12
color = Color(1.0, 0.85, 0.2, 0.9)
emission_shape = 1
emission_sphere_radius = 0.25

[sub_resource type="SphereMesh" id="SphereMesh_particle"]
radius = 0.05
height = 0.1

[node name="Beschwoerungsraum" type="Node3D"]
script = ExtResource("1_script")

; === Level Geometrie — Kenney Modular Dungeon ===
[node name="LevelGeometry" type="Node3D" parent="."]

; Hauptraum: room-small als Basis des Beschwoerungsraums (Kellerraum, ~4×4m)
[node name="RoomBase" parent="LevelGeometry" instance=ExtResource("10_room_small")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0)

; Zweiter room-small-Block versetzt für größere Fläche
[node name="RoomBase2" parent="LevelGeometry" instance=ExtResource("10_room_small")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -4)

; Ecken des Raums
[node name="CornerNW" parent="LevelGeometry" instance=ExtResource("13_corner")]
transform = Transform3D(0, 0, 1, 0, 1, 0, -1, 0, 0, -5, 0, -5)

[node name="CornerNE" parent="LevelGeometry" instance=ExtResource("13_corner")]
transform = Transform3D(-1, 0, 0, 0, 1, 0, 0, 0, -1, 5, 0, -5)

[node name="CornerSW" parent="LevelGeometry" instance=ExtResource("13_corner")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -5, 0, 5)

[node name="CornerSE" parent="LevelGeometry" instance=ExtResource("13_corner")]
transform = Transform3D(0, 0, -1, 0, 1, 0, 1, 0, 0, 5, 0, 5)

; Eingangs-Tor (Südseite, z=6.5)
[node name="EntranceGate" parent="LevelGeometry" instance=ExtResource("11_gate_door")]
transform = Transform3D(-1, 0, 0, 0, 1, 0, 0, 0, -1, 0, 0, 6)

; Treppe am Eingang (Keller → Aufgang)
[node name="EntranceStairs" parent="LevelGeometry" instance=ExtResource("12_stairs")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 5)

[node name="Collision" type="Node3D" parent="."]

[node name="FloorCollider" type="StaticBody3D" parent="Collision"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.2, 0)
[node name="CollisionShape3D" type="CollisionShape3D" parent="Collision/FloorCollider"]
shape = SubResource("BoxShape_floor")

[node name="WallNorth" type="StaticBody3D" parent="Collision"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 4, -7)
[node name="CollisionShape3D" type="CollisionShape3D" parent="Collision/WallNorth"]
