[gd_scene load_steps=2 format=3 uid="uid://datasoul_mainmenu"]

[ext_resource type="Script" path="res://scripts/ui/MainMenuController.cs" id="1_ctrl"]

; =====================================================================
; MainMenu — DataSoul
; Dunkler Anime/Mittelalter-Stil (Referenz: .hack)
; Hintergrund: #0a0d14 (fast schwarz, leicht bläulich)
; Akzentfarbe: #00e5ff (cyan-blau)
; =====================================================================

[node name="MainMenu" type="Control"]
script = ExtResource("1_ctrl")
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 0

; ─────────────────────────────────────────────
; Hintergrund (dunkel-bläulich)
; ─────────────────────────────────────────────
[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.039, 0.051, 0.078, 1)
mouse_filter = 2

; ─────────────────────────────────────────────
; Partikel-Layer (schwebende Datenfragmente)
; ─────────────────────────────────────────────
[node name="ParticleLayer" type="Node" parent="."]

[node name="Particles" type="GPUParticles2D" parent="ParticleLayer"]
position = Vector2(640, 360)
amount = 60
lifetime = 8.0
speed_scale = 0.4
local_coords = false
process_material = SubResource("particle_material")
texture = null

[sub_resource type="ParticleProcessMaterial" id="particle_material"]
direction = Vector3(0, -1, 0)
spread = 180.0
initial_velocity_min = 10.0
initial_velocity_max = 40.0
gravity = Vector3(0, -5, 0)
scale_min = 1.5
scale_max = 3.5
color = Color(0.0, 0.898, 1.0, 0.45)
emission_shape = 3
emission_box_extents = Vector3(640, 360, 0)

