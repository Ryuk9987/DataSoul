[node name="WallWest" type="StaticBody3D" parent="Collision"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7, 4, 0)
[node name="CollisionShape3D" type="CollisionShape3D" parent="Collision/WallWest"]
shape = SubResource("BoxShape_wallEW")

