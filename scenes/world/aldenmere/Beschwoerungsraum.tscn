[node name="WallSouth" type="StaticBody3D" parent="Collision"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 4, 7)
[node name="CollisionShape3D" type="CollisionShape3D" parent="Collision/WallSouth"]
